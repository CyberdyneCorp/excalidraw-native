{
  "name": "@cyberdynecorp/svelte",
  "version": "0.1.0",
  "description": "Reactive editor store + Svelte 5 bridge over @cyberdynecorp/editor and @cyberdynecorp/render.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@cyberdynecorp/editor": "workspace:*",
    "@cyberdynecorp/geometry": "workspace:*",
    "@cyberdynecorp/math": "workspace:*",
    "@cyberdynecorp/model": "workspace:*",
    "@cyberdynecorp/protocol": "workspace:*",
    "@cyberdynecorp/render": "workspace:*"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "@cyberdynecorp/server": "workspace:*",
    "typescript": "^5.7.2",
    "ws": "^8.18.0"
  },
  "license": "MIT",
  "author": "Cyberdyne Corp AI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonardoaraujosantos/excalidraw-swift.git",
    "directory": "web/packages/svelte"
  },
  "homepage": "https://github.com/leonardoaraujosantos/excalidraw-swift#readme",
  "module": "./dist/index.js",
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
